<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="CSK Scorer">
<meta name="theme-color" content="#0d1f3c">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-192.png">
<title>Chennai Sydney Kings — Live Scorer</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --grass:#0a1628; --pitch:#0d1f3c; --amber:#c9a227; --red:#ef4444;
    --white:#ffffff; --card:rgba(255,255,255,0.06); --border:rgba(255,255,255,0.12);
    --text:#e8e4dc; --muted:rgba(232,228,220,0.55);
    --wide-color:#f59e0b; --wicket-color:#ef4444; --bye-color:#60a5fa;
    --run-color:#4ade80; --dot-color:rgba(232,228,220,0.3);
    --safe-top:env(safe-area-inset-top,0px); --safe-bottom:env(safe-area-inset-bottom,0px);
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;overflow:hidden;}
  body{background:var(--grass);background-image:repeating-linear-gradient(0deg,transparent,transparent 40px,rgba(201,162,39,0.04) 40px,rgba(201,162,39,0.04) 41px),repeating-linear-gradient(90deg,transparent,transparent 40px,rgba(201,162,39,0.04) 40px,rgba(201,162,39,0.04) 41px);font-family:'DM Sans',sans-serif;color:var(--text);display:flex;flex-direction:column;padding-top:var(--safe-top);padding-bottom:var(--safe-bottom);}

  /* HEADER */
  header{background:linear-gradient(135deg,#0a1628,#0d1f3c,#0a1628);border-bottom:2px solid var(--amber);padding:8px 14px 6px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;box-shadow:0 4px 20px rgba(0,0,0,0.4);}
  .logo{display:flex;align-items:center;}
  .logo span{color:var(--white);}
  .hdr-right{text-align:right;}
  .hdr-runs-line{font-family:'Bebas Neue',sans-serif;font-size:2rem;line-height:1;color:var(--white);letter-spacing:1px;}
  .hdr-runs-line .sep{color:var(--amber);}
  .hdr-runs-line .wk{color:#ef4444;}
  .hdr-meta{font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--muted);}

  /* BATSMEN BAR */
  .batsmen-bar{background:rgba(0,0,0,0.4);border-bottom:1px solid var(--border);padding:6px 14px;display:flex;gap:6px;flex-shrink:0;align-items:stretch;}
  .batsman-card{flex:1;background:var(--card);border:1px solid var(--border);border-radius:9px;padding:5px 9px;display:flex;flex-direction:column;gap:1px;min-width:0;}
  .batsman-card.on-strike{border-color:var(--amber);background:rgba(245,158,11,0.08);}
  .batsman-card.on-strike .bat-name::before{content:'🏏 ';}
  .bat-name{font-size:0.78rem;font-weight:600;color:var(--white);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .bat-stats{font-family:'DM Mono',monospace;font-size:0.65rem;color:var(--muted);}
  .bat-stats .bat-runs{color:var(--run-color);font-weight:700;}

  /* LIVE BAR */
  .live-bar{background:rgba(0,0,0,0.3);border-bottom:1px solid var(--border);padding:5px 14px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
  .live-dot{display:flex;align-items:center;gap:5px;font-size:0.68rem;color:var(--muted);}
  .live-dot .dot{width:7px;height:7px;border-radius:50%;background:#ef4444;animation:pulse 1.5s infinite;flex-shrink:0;}
  .live-dot .dot.synced{background:#4ade80;animation:none;}
  .live-dot .dot.offline{background:var(--amber);animation:none;}
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.8)}}
  .scorer-badge{font-size:0.68rem;padding:3px 9px;border-radius:20px;font-weight:600;letter-spacing:0.5px;white-space:nowrap;cursor:pointer;}
  .scorer-badge.is-scorer{background:rgba(74,222,128,0.2);color:#4ade80;border:1px solid rgba(74,222,128,0.4);}
  .scorer-badge.is-watcher{background:rgba(245,158,11,0.15);color:var(--amber);border:1px solid rgba(245,158,11,0.3);}

  /* TABS */
  .tabs{display:flex;background:rgba(0,0,0,0.3);border-bottom:1px solid var(--border);flex-shrink:0;}
  .tab{flex:1;padding:8px 2px;text-align:center;font-size:0.62rem;font-weight:600;letter-spacing:0.6px;text-transform:uppercase;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;user-select:none;}
  .tab.active{color:var(--amber);border-bottom-color:var(--amber);background:rgba(245,158,11,0.05);}
  .tab-content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;display:none;flex-direction:column;}
  .tab-content.active{display:flex;}

  /* SPECTATOR OVERLAY */
  .spectator-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.6);z-index:50;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px);}
  .takeover-card{background:linear-gradient(135deg,#0a1628,#0d1f3c);border:2px solid var(--amber);border-radius:16px;padding:22px 18px;text-align:center;max-width:280px;width:90%;}
  .takeover-card .icon{font-size:2rem;margin-bottom:6px;}
  .takeover-card h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:var(--amber);margin-bottom:5px;}
  .takeover-card p{font-size:0.78rem;color:var(--muted);margin-bottom:14px;line-height:1.5;}
  .btn-takeover{background:rgba(74,222,128,0.2);color:#4ade80;border:1px solid rgba(74,222,128,0.45);border-radius:10px;padding:11px 18px;font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:2px;cursor:pointer;width:100%;margin-bottom:7px;touch-action:manipulation;}
  .btn-watch{background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:10px;padding:9px 18px;font-family:'DM Sans',sans-serif;font-size:0.8rem;cursor:pointer;width:100%;touch-action:manipulation;}

  /* NEW BATSMAN MODAL */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
  .modal-overlay.show{display:flex;}
  .modal-card{background:linear-gradient(135deg,#0a1628,#0d1f3c);border:2px solid var(--wicket-color);border-radius:16px;padding:22px 18px;text-align:center;max-width:300px;width:92%;}
  .modal-card h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:var(--wicket-color);margin-bottom:4px;}
  .modal-card p{font-size:0.78rem;color:var(--muted);margin-bottom:14px;}
  .modal-card input{background:rgba(0,0,0,0.35);border:1px solid var(--border);border-radius:9px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:1rem;padding:11px 13px;width:100%;outline:none;margin-bottom:10px;}
  .modal-card input:focus{border-color:var(--wicket-color);}
  .btn-confirm{background:rgba(239,68,68,0.2);color:var(--wicket-color);border:1px solid rgba(239,68,68,0.4);border-radius:10px;padding:12px;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;cursor:pointer;width:100%;touch-action:manipulation;}

  /* SCORE TAB */
  .score-wrapper{position:relative;flex:1;display:flex;flex-direction:column;min-height:0;}
  .ball-strip{background:rgba(0,0,0,0.25);padding:7px 11px;display:flex;align-items:center;gap:5px;flex-wrap:wrap;min-height:48px;border-bottom:1px solid var(--border);flex-shrink:0;}
  .ball-strip-label{font-size:0.64rem;color:var(--muted);letter-spacing:0.5px;margin-right:4px;white-space:nowrap;}
  .ball-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:0.72rem;font-weight:600;border:2px solid;flex-shrink:0;}
  .ball-dot.dot   {background:rgba(255,255,255,0.05);border-color:var(--dot-color);color:var(--muted);}
  .ball-dot.run1,.ball-dot.run2,.ball-dot.run3{background:rgba(74,222,128,0.15);border-color:var(--run-color);color:var(--run-color);}
  .ball-dot.run4  {background:rgba(74,222,128,0.3);border-color:#22c55e;color:#22c55e;}
  .ball-dot.run6  {background:rgba(74,222,128,0.4);border-color:#16a34a;color:#16a34a;font-weight:700;}
  .ball-dot.wide  {background:rgba(245,158,11,0.15);border-color:var(--wide-color);color:var(--wide-color);}
  .ball-dot.wicket{background:rgba(239,68,68,0.2);border-color:var(--wicket-color);color:var(--wicket-color);font-weight:700;}
  .ball-dot.bye   {background:rgba(96,165,250,0.15);border-color:var(--bye-color);color:var(--bye-color);}
  .ball-dot.noball{background:rgba(168,85,247,0.15);border-color:#a855f7;color:#a855f7;}
  .ball-placeholder{width:32px;height:32px;border-radius:50%;border:2px dashed rgba(255,255,255,0.08);flex-shrink:0;}

  .bowler-row{padding:6px 12px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border);flex-shrink:0;background:rgba(0,0,0,0.15);}
  .bowler-label{font-size:0.68rem;color:var(--muted);white-space:nowrap;}
  .bowler-row input{flex:1;background:rgba(0,0,0,0.3);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.88rem;padding:5px 9px;outline:none;}
  .bowler-row input:focus{border-color:var(--amber);}
  .bowler-row input::placeholder{color:var(--muted);}

  /* BUTTONS */
  .btn-grid{padding:7px 9px;display:grid;grid-template-columns:repeat(4,1fr);gap:6px;flex-shrink:0;}
  .btn{border:none;border-radius:10px;cursor:pointer;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:1px;padding:11px 4px;transition:all 0.12s;touch-action:manipulation;display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1.1;}
  .btn:active{transform:scale(0.91);filter:brightness(0.82);}
  .btn-sub{font-family:'DM Sans',sans-serif;font-size:0.48rem;opacity:0.7;margin-top:1px;}
  .btn-dot {background:rgba(255,255,255,0.07);color:var(--muted);border:1px solid var(--border);}
  .btn-run {background:rgba(74,222,128,0.13);color:var(--run-color);border:1px solid rgba(74,222,128,0.28);}
  .btn-four{background:rgba(74,222,128,0.22);color:#22c55e;border:1px solid rgba(34,197,94,0.4);font-size:1.1rem;}
  .btn-six {background:rgba(74,222,128,0.32);color:#16a34a;border:1px solid rgba(22,163,74,0.5);font-size:1.1rem;}
  .btn-wide{background:rgba(245,158,11,0.13);color:var(--wide-color);border:1px solid rgba(245,158,11,0.3);}
  .btn-wkt {background:rgba(239,68,68,0.18);color:var(--wicket-color);border:1px solid rgba(239,68,68,0.38);}
  .btn-bye {background:rgba(96,165,250,0.13);color:var(--bye-color);border:1px solid rgba(96,165,250,0.3);}
  .btn-nb  {background:rgba(168,85,247,0.13);color:#a855f7;border:1px solid rgba(168,85,247,0.3);}
  .btn-undo{background:rgba(255,255,255,0.05);color:var(--muted);border:1px solid var(--border);}
  .btn-end {background:rgba(245,158,11,0.18);color:var(--amber);border:1px solid rgba(245,158,11,0.4);}
  .btn-span2{grid-column:span 2;}

  /* EXTRAS */
  .extras-bar{display:flex;border-top:1px solid var(--border);flex-shrink:0;}
  .extras-bar>div{flex:1;text-align:center;padding:5px 2px;border-right:1px solid var(--border);}
  .extras-bar>div:last-child{border-right:none;}
  .ext-label{color:var(--muted);display:block;font-size:0.56rem;letter-spacing:0.4px;}
  .ext-val{font-family:'DM Mono',monospace;font-weight:600;color:var(--text);font-size:0.82rem;}

  /* LEGEND */
  .legend-row{display:flex;gap:7px;flex-wrap:wrap;padding:5px 11px;border-top:1px solid var(--border);background:rgba(0,0,0,0.15);flex-shrink:0;}
  .legend-item{display:flex;align-items:center;gap:3px;font-size:0.58rem;color:var(--muted);}
  .legend-dot{width:9px;height:9px;border-radius:50%;border:1.5px solid;flex-shrink:0;}

  /* SCOREBOOK & BATTING CARD */
  .scorebook-content,.batting-content{flex:1;}
  .section-title{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--amber);padding:10px 12px 6px;border-bottom:1px solid var(--border);}
  .empty-state{text-align:center;padding:36px 24px;color:var(--muted);font-size:0.82rem;}
  .empty-state .icon{font-size:2rem;margin-bottom:10px;}

  table{width:100%;border-collapse:collapse;font-size:0.77rem;}
  thead th{background:rgba(0,0,0,0.35);color:var(--muted);font-size:0.58rem;font-weight:600;letter-spacing:0.8px;text-transform:uppercase;padding:7px 8px;text-align:left;border-bottom:1px solid var(--border);position:sticky;top:0;}
  tbody tr{border-bottom:1px solid rgba(255,255,255,0.05);}
  tbody tr:last-child{border-bottom:none;}
  td{padding:7px 8px;}
  td.name-col{font-weight:600;color:var(--white);}
  td.runs-col{color:var(--run-color);font-family:'DM Mono',monospace;font-weight:700;}
  td.wkts-col{color:var(--wicket-color);font-family:'DM Mono',monospace;}
  td.score-col{color:var(--amber);font-family:'DM Mono',monospace;font-weight:600;}
  td.muted-col{color:var(--muted);font-family:'DM Mono',monospace;}
  td.strike-col{color:var(--amber);}
  .out-row td{opacity:0.55;}
  .not-out-badge{font-size:0.58rem;color:#4ade80;margin-left:3px;}
  .out-badge{font-size:0.58rem;color:var(--wicket-color);margin-left:3px;}

  .ball-seq{display:flex;gap:3px;flex-wrap:wrap;}
  .mini-ball{display:inline-flex;align-items:center;justify-content:center;width:19px;height:19px;border-radius:50%;font-size:0.54rem;font-weight:700;border:1.5px solid;}
  .mini-ball.dot   {background:rgba(255,255,255,0.04);border-color:var(--dot-color);color:var(--muted);}
  .mini-ball.run1,.mini-ball.run2,.mini-ball.run3{background:rgba(74,222,128,0.12);border-color:var(--run-color);color:var(--run-color);}
  .mini-ball.run4  {background:rgba(74,222,128,0.25);border-color:#22c55e;color:#22c55e;}
  .mini-ball.run6  {background:rgba(74,222,128,0.35);border-color:#16a34a;color:#16a34a;}
  .mini-ball.wide  {background:rgba(245,158,11,0.12);border-color:var(--wide-color);color:var(--wide-color);}
  .mini-ball.wicket{background:rgba(239,68,68,0.18);border-color:var(--wicket-color);color:var(--wicket-color);}
  .mini-ball.bye   {background:rgba(96,165,250,0.12);border-color:var(--bye-color);color:var(--bye-color);}
  .mini-ball.noball{background:rgba(168,85,247,0.12);border-color:#a855f7;color:#a855f7;}

  /* STATS */
  .stats-content{padding:11px 9px;display:grid;grid-template-columns:1fr 1fr;gap:8px;align-content:start;}
  .stat-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 11px;}
  .stat-label{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.8px;color:var(--muted);margin-bottom:3px;}
  .stat-value{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;line-height:1;color:var(--amber);}
  .stat-sub{font-size:0.62rem;color:var(--muted);margin-top:2px;}

  /* SETUP */
  .setup-content{padding:12px 11px;display:flex;flex-direction:column;gap:11px;}
  .setup-group{display:flex;flex-direction:column;gap:4px;}
  .setup-label{font-size:0.68rem;color:var(--muted);}
  .setup-content input,.setup-content select{background:rgba(0,0,0,0.3);border:1px solid var(--border);border-radius:9px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.95rem;padding:10px 12px;width:100%;outline:none;}
  .setup-content input:focus,.setup-content select:focus{border-color:var(--amber);}
  .setup-content select option{background:#0a1628;}
  .setup-divider{height:1px;background:var(--border);}
  .btn-apply{background:rgba(245,158,11,0.22);color:var(--amber);border:1px solid rgba(245,158,11,0.5);border-radius:10px;padding:13px;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;cursor:pointer;width:100%;touch-action:manipulation;}
  .btn-reset-m{background:rgba(239,68,68,0.12);color:#ef4444;border:1px solid rgba(239,68,68,0.35);border-radius:10px;padding:11px;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;cursor:pointer;width:100%;touch-action:manipulation;}
  .btn-update-settings{background:rgba(74,222,128,0.15);color:#4ade80;border:1px solid rgba(74,222,128,0.4);border-radius:10px;padding:13px;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;cursor:pointer;width:100%;touch-action:manipulation;}

  /* COMPLETE */
  .complete-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.88);display:none;align-items:center;justify-content:center;z-index:999;padding:24px;backdrop-filter:blur(6px);}
  .complete-overlay.show{display:flex;}
  .complete-card{background:linear-gradient(135deg,#0a1628,#0d1f3c);border:2px solid var(--amber);border-radius:18px;padding:24px 18px;text-align:center;width:100%;max-width:320px;}
  .complete-card .trophy{font-size:2.5rem;margin-bottom:5px;}
  .complete-card h2{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;color:var(--amber);margin-bottom:3px;}
  .final-score{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;color:var(--white);line-height:1;margin:8px 0 3px;}
  .final-meta{font-size:0.8rem;color:var(--muted);margin-bottom:16px;}
  .btn-new-match{background:rgba(245,158,11,0.22);color:var(--amber);border:1px solid rgba(245,158,11,0.5);border-radius:10px;padding:12px 24px;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;cursor:pointer;touch-action:manipulation;width:100%;}

  /* TOAST */
  .toast{position:fixed;bottom:calc(60px + var(--safe-bottom));left:50%;transform:translateX(-50%) translateY(16px);background:rgba(20,20,20,0.96);color:var(--text);padding:8px 16px;border-radius:20px;font-size:0.78rem;border:1px solid var(--border);opacity:0;transition:all 0.28s;z-index:998;white-space:nowrap;pointer-events:none;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  /* INSTALL */
  .install-banner{background:rgba(245,158,11,0.12);border-bottom:1px solid rgba(245,158,11,0.25);padding:6px 12px;font-size:0.72rem;color:var(--amber);display:none;flex-shrink:0;align-items:center;justify-content:center;gap:5px;}
  .install-banner.show{display:flex;}

  /* UNDO STRIP */
  .undo-strip{display:none;background:rgba(239,68,68,0.08);border-bottom:1px solid rgba(239,68,68,0.25);padding:5px 12px;align-items:center;justify-content:space-between;flex-shrink:0;gap:8px;}
  .undo-strip.show{display:flex;}
  .undo-last-desc{font-size:0.68rem;color:rgba(239,68,68,0.8);font-family:'DM Mono',monospace;}
  .btn-undo-strip{background:rgba(239,68,68,0.18);color:#ef4444;border:1px solid rgba(239,68,68,0.45);border-radius:8px;padding:6px 14px;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:1.5px;cursor:pointer;touch-action:manipulation;white-space:nowrap;flex-shrink:0;}
  .btn-undo-strip:active{transform:scale(0.93);}

  /* INNINGS BANNER */
  .innings-banner{background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.07));border-bottom:2px solid rgba(245,158,11,0.4);padding:6px 14px;display:none;align-items:center;justify-content:space-between;flex-shrink:0;}
  .innings-banner.show{display:flex;}
  .innings-banner-label{font-family:'Bebas Neue',sans-serif;font-size:0.9rem;letter-spacing:2px;color:var(--amber);}
  .innings-banner-meta{font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--muted);}

  /* END INNINGS OVERLAY */
  .end-innings-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.9);display:none;align-items:center;justify-content:center;z-index:998;padding:24px;backdrop-filter:blur(6px);}
  .end-innings-overlay.show{display:flex;}
  .end-innings-card{background:linear-gradient(135deg,#0a1628,#0d1f3c);border:2px solid var(--amber);border-radius:18px;padding:26px 20px;text-align:center;width:100%;max-width:340px;}
  .end-innings-card .ei-icon{font-size:2.2rem;margin-bottom:6px;}
  .end-innings-card h2{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:3px;color:var(--amber);margin-bottom:4px;}
  .ei-score{font-family:'Bebas Neue',sans-serif;font-size:3.2rem;color:var(--white);line-height:1;margin:8px 0 4px;}
  .ei-meta{font-size:0.78rem;color:var(--muted);margin-bottom:18px;line-height:1.5;}
  .btn-start-2nd{background:rgba(74,222,128,0.2);color:#4ade80;border:1px solid rgba(74,222,128,0.5);border-radius:10px;padding:13px 24px;font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:2px;cursor:pointer;touch-action:manipulation;width:100%;margin-bottom:8px;}
  .btn-new-from-ei{background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:10px;padding:10px;font-family:'DM Sans',sans-serif;font-size:0.82rem;cursor:pointer;width:100%;touch-action:manipulation;}

  /* SR indicator */
  .sr-good{color:#4ade80;}
  .sr-ok{color:var(--amber);}
  .sr-slow{color:#ef4444;}

  /* RECALL MODAL */
  .recall-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:300;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(4px);}
  .recall-modal-overlay.show{display:flex;}
  .recall-modal-card{background:linear-gradient(135deg,#0a1628,#0d1f3c);border:2px solid #4ade80;border-radius:18px 18px 0 0;padding:20px 16px 28px;width:100%;max-width:420px;}
  .recall-modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:2px;color:#4ade80;margin-bottom:4px;}
  .recall-modal-sub{font-size:0.75rem;color:var(--muted);margin-bottom:16px;}
  .recall-choice-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
  .btn-recall-choice{border:none;border-radius:12px;cursor:pointer;padding:14px 8px;touch-action:manipulation;background:rgba(74,222,128,0.13);color:#4ade80;border:1px solid rgba(74,222,128,0.35);transition:all 0.12s;text-align:center;}
  .btn-recall-choice:active{transform:scale(0.94);}
  .btn-recall-choice .rchoice-role{font-family:'Bebas Neue',sans-serif;font-size:0.9rem;letter-spacing:1px;display:block;margin-bottom:3px;}
  .btn-recall-choice .rchoice-name{font-size:0.72rem;color:var(--muted);display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .extras-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:300;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(4px);}
  .extras-modal-overlay.show{display:flex;}
  .extras-modal-card{background:linear-gradient(135deg,#0a1628,#0d1f3c);border:2px solid var(--wide-color);border-radius:18px 18px 0 0;padding:18px 16px 28px;width:100%;max-width:420px;}
  .extras-modal-card.nb-mode{border-color:#a855f7;}
  .extras-modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:2px;color:var(--wide-color);margin-bottom:4px;}
  .extras-modal-card.nb-mode .extras-modal-title{color:#a855f7;}
  .extras-modal-sub{font-size:0.75rem;color:var(--muted);margin-bottom:14px;}
  .extras-run-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;margin-bottom:14px;}
  .btn-erun{border:none;border-radius:10px;cursor:pointer;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;padding:13px 4px;touch-action:manipulation;background:rgba(245,158,11,0.13);color:var(--wide-color);border:1px solid rgba(245,158,11,0.3);transition:all 0.12s;}
  .btn-erun:active{transform:scale(0.91);}
  .nb-mode .btn-erun{background:rgba(168,85,247,0.13);color:#a855f7;border-color:rgba(168,85,247,0.3);}
  .btn-ecancel{width:100%;background:rgba(255,255,255,0.05);color:var(--muted);border:1px solid var(--border);border-radius:10px;padding:10px;font-family:'DM Sans',sans-serif;font-size:0.85rem;cursor:pointer;touch-action:manipulation;}

  /* RETIRED OUT BUTTON */
  .btn-retire{font-size:0.58rem;background:rgba(245,158,11,0.12);color:var(--amber);border:1px solid rgba(245,158,11,0.3);border-radius:6px;padding:2px 6px;cursor:pointer;margin-top:3px;touch-action:manipulation;font-family:'DM Sans',sans-serif;white-space:nowrap;display:inline-block;}
  .btn-retire:active{opacity:0.7;}

  /* HISTORY TAB */
  .history-content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:10px 10px 20px;}
  .history-header{display:flex;align-items:center;justify-content:space-between;padding:10px 12px 6px;border-bottom:1px solid var(--border);}
  .history-header .section-title{padding:0;border:none;}
  .btn-clear-hist{background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:5px 11px;font-size:0.7rem;font-family:'DM Sans',sans-serif;cursor:pointer;touch-action:manipulation;}
  .match-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:13px 13px 10px;margin-bottom:9px;cursor:pointer;transition:border-color 0.2s;}
  .match-card:active{border-color:var(--amber);}
  .match-card-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:5px;}
  .match-teams{font-weight:600;font-size:0.85rem;color:var(--white);}
  .match-date{font-size:0.62rem;color:var(--muted);white-space:nowrap;margin-left:8px;padding-top:2px;}
  .match-score-line{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--amber);line-height:1;}
  .match-meta-row{display:flex;gap:10px;margin-top:4px;flex-wrap:wrap;}
  .match-chip{font-size:0.62rem;background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:6px;padding:2px 7px;color:var(--muted);}
  .match-chip.win{border-color:rgba(74,222,128,0.4);color:#4ade80;}

  /* MATCH DETAIL MODAL */
  .hist-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:300;display:none;flex-direction:column;backdrop-filter:blur(5px);}
  .hist-modal-overlay.show{display:flex;}
  .hist-modal-inner{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px 14px 30px;}
  .hist-modal-header{display:flex;align-items:center;justify-content:space-between;padding:12px 14px 8px;border-bottom:1px solid var(--border);background:rgba(10,22,40,0.98);flex-shrink:0;position:sticky;top:0;z-index:1;}
  .hist-modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;color:var(--amber);}
  .btn-hist-close{background:rgba(255,255,255,0.07);color:var(--text);border:1px solid var(--border);border-radius:8px;padding:6px 13px;font-size:0.8rem;cursor:pointer;touch-action:manipulation;}
  .hist-big-score{font-family:'Bebas Neue',sans-serif;font-size:3rem;color:var(--white);text-align:center;line-height:1;margin:12px 0 2px;}
  .hist-teams-line{text-align:center;font-size:0.85rem;color:var(--muted);margin-bottom:14px;}
  .hist-section{font-family:'Bebas Neue',sans-serif;font-size:0.9rem;letter-spacing:1.5px;color:var(--amber);margin:14px 0 7px;padding-bottom:4px;border-bottom:1px solid var(--border);}
</style>
</head>
<body>

<div class="install-banner" id="install-banner"></div>

<!-- HEADER -->
<header>
  <div class="logo"><img src="data:image/jpeg;base64," alt="Chennai Sydney Kings" style="height:42px;width:auto;object-fit:contain;filter:drop-shadow(0 2px 6px rgba(201,162,39,0.4));"></div>
  <div class="hdr-right">
    <div class="hdr-runs-line"><span id="hdr-runs">0</span><span class="sep">/</span><span class="wk" id="hdr-wkts">0</span></div>
    <div class="hdr-meta" id="hdr-meta">0.0 ov · RR: 0.00</div>
  </div>
</header>

<!-- BATSMEN BAR -->
<div class="batsmen-bar" id="batsmen-bar">
  <div class="batsman-card on-strike" id="bat0-card">
    <div class="bat-name" id="bat0-name">Batsman 1</div>
    <div class="bat-stats"><span class="bat-runs" id="bat0-runs">0</span> (<span id="bat0-balls">0</span>b) · 4s:<span id="bat0-fours">0</span> 6s:<span id="bat0-sixes">0</span></div>
    <div id="bat0-retire"></div>
  </div>
  <div class="batsman-card" id="bat1-card">
    <div class="bat-name" id="bat1-name">Batsman 2</div>
    <div class="bat-stats"><span class="bat-runs" id="bat1-runs">0</span> (<span id="bat1-balls">0</span>b) · 4s:<span id="bat1-fours">0</span> 6s:<span id="bat1-sixes">0</span></div>
    <div id="bat1-retire"></div>
  </div>
</div>

<!-- LIVE BAR -->
<div class="live-bar">
  <div class="live-dot"><div class="dot" id="sync-dot"></div><span id="sync-label">Connecting...</span></div>
  <div id="scorer-badge" class="scorer-badge is-watcher" onclick="tryTakeOver()">👁 WATCHING — Tap to Score</div>
</div>

<!-- TABS -->
<div class="tabs">
  <div class="tab active" onclick="switchTab('score')">🎯 Score</div>
  <div class="tab" onclick="switchTab('batting')">🏏 Batting</div>
  <div class="tab" onclick="switchTab('book')">📋 Book</div>
  <div class="tab" onclick="switchTab('stats')">📊 Stats</div>
  <div class="tab" onclick="switchTab('history')">🗂 History</div>
  <div class="tab" onclick="switchTab('setup')">⚙️ Setup</div>
</div>

<!-- SCORE TAB -->
<div class="tab-content active" id="tab-score">
  <div class="score-wrapper">
    <div class="spectator-overlay" id="spectator-overlay">
      <div class="takeover-card">
        <div class="icon">🏏</div>
        <h3>Join the Game</h3>
        <p>Watch live or take over scoring from where it left off.</p>
        <button class="btn-takeover" onclick="takeOver()">✏️ TAKE OVER SCORING</button>
        <button class="btn-watch" onclick="watchOnly()">👁 Just Watch Live</button>
      </div>
    </div>

    <!-- INNINGS BANNER (shown during 2nd innings) -->
    <div class="innings-banner" id="innings-banner">
      <span class="innings-banner-label" id="innings-banner-label">2ND INNINGS</span>
      <span class="innings-banner-meta" id="innings-banner-meta"></span>
    </div>

    <div class="ball-strip" id="ball-strip">
      <span class="ball-strip-label">Ov 1 · B 1</span>
      <span style="color:var(--muted);font-size:0.7rem;margin-left:6px">Waiting...</span>
    </div>

    <!-- UNDO STRIP — visible after each ball scored, before next delivery -->
    <div class="undo-strip" id="undo-strip">
      <span class="undo-last-desc" id="undo-last-desc">Last: —</span>
      <button class="btn-undo-strip" onclick="undoLast()">↩ UNDO LAST BALL</button>
    </div>

    <div class="bowler-row">
      <span class="bowler-label">BOWLER</span>
      <input type="text" id="bowler-name" placeholder="Bowler name..." autocomplete="off" autocorrect="off">
    </div>

    <div class="btn-grid">
      <button class="btn btn-dot"  onclick="score('dot')">•<span class="btn-sub">DOT</span></button>
      <button class="btn btn-run"  onclick="score('1')">1<span class="btn-sub">RUN</span></button>
      <button class="btn btn-run"  onclick="score('2')">2<span class="btn-sub">RUNS</span></button>
      <button class="btn btn-run"  onclick="score('3')">3<span class="btn-sub">RUNS</span></button>
      <button class="btn btn-four" onclick="score('4')">4<span class="btn-sub">FOUR</span></button>
      <button class="btn btn-six"  onclick="score('6')">6<span class="btn-sub">SIX</span></button>
      <button class="btn btn-wide" onclick="openExtrasModal('wide')">W<span class="btn-sub">WIDE</span></button>
      <button class="btn btn-wkt"  onclick="score('wicket')">WKT<span class="btn-sub">OUT</span></button>
      <button class="btn btn-bye"  onclick="score('1b')">1<span class="btn-sub">BYE</span></button>
      <button class="btn btn-bye"  onclick="score('2b')">2<span class="btn-sub">BYES</span></button>
      <button class="btn btn-bye"  onclick="score('3b')">3<span class="btn-sub">BYES</span></button>
      <button class="btn btn-nb"   onclick="openExtrasModal('nb')">NB<span class="btn-sub">NO BALL</span></button>
      <button class="btn btn-undo btn-span2" onclick="undoLast()">↩ UNDO</button>
      <button class="btn btn-end  btn-span2" onclick="endOver()">END OVER</button>
      <button class="btn btn-span2" style="background:rgba(245,158,11,0.12);color:var(--amber);border:1px solid rgba(245,158,11,0.3);font-size:0.78rem;letter-spacing:0.8px;" onclick="endInnings()">🏏 END 1ST INNINGS</button>
    </div>

    <div class="extras-bar">
      <div><span class="ext-label">WIDES</span><span class="ext-val" id="ext-wides">0</span></div>
      <div><span class="ext-label">NO BALLS</span><span class="ext-val" id="ext-nb">0</span></div>
      <div><span class="ext-label">BYES</span><span class="ext-val" id="ext-byes">0</span></div>
      <div><span class="ext-label">EXTRAS</span><span class="ext-val" id="ext-total">0</span></div>
    </div>
    <div class="legend-row">
      <div class="legend-item"><div class="legend-dot" style="border-color:var(--dot-color)"></div>Dot</div>
      <div class="legend-item"><div class="legend-dot" style="border-color:var(--run-color)"></div>Runs</div>
      <div class="legend-item"><div class="legend-dot" style="border-color:var(--wide-color)"></div>Wide</div>
      <div class="legend-item"><div class="legend-dot" style="border-color:var(--wicket-color)"></div>Wicket</div>
      <div class="legend-item"><div class="legend-dot" style="border-color:var(--bye-color)"></div>Bye</div>
      <div class="legend-item"><div class="legend-dot" style="border-color:#a855f7"></div>NB</div>
    </div>
  </div>
</div>

<!-- BATTING TAB -->
<div class="tab-content" id="tab-batting">
  <div class="batting-content">
    <div class="section-title">🏏 BATTING SCORECARD</div>
    <div class="empty-state" id="batting-empty"><div class="icon">🏏</div>No batsmen added yet</div>
    <table id="batting-table" style="display:none">
      <thead>
        <tr>
          <th>Batsman</th><th>R</th><th>B</th><th>4s</th><th>6s</th><th>SR</th><th>Status</th>
        </tr>
      </thead>
      <tbody id="batting-body"></tbody>
    </table>
  </div>
</div>

<!-- SCOREBOOK TAB -->
<div class="tab-content" id="tab-book">
  <div class="scorebook-content">
    <div class="section-title">📋 OVER BY OVER</div>
    <div class="empty-state" id="book-empty"><div class="icon">📋</div>Complete an over to see the scorebook</div>
    <table id="book-table" style="display:none">
      <thead><tr><th>Ov</th><th>Bowler</th><th>Balls</th><th>Runs</th><th>Wkt</th><th>Score</th></tr></thead>
      <tbody id="book-body"></tbody>
    </table>
  </div>
</div>

<!-- STATS TAB -->
<div class="tab-content" id="tab-stats">
  <div class="stats-content">
    <div class="stat-card"><div class="stat-label">Run Rate</div><div class="stat-value" id="stat-rr">0.00</div><div class="stat-sub">per over</div></div>
    <div class="stat-card"><div class="stat-label">Required RR</div><div class="stat-value" id="stat-rrr">—</div><div class="stat-sub" id="stat-rrr-sub">set target</div></div>
    <div class="stat-card"><div class="stat-label">Boundaries</div><div class="stat-value" id="stat-boundaries">0</div><div class="stat-sub" id="stat-bound-sub">4s:0 · 6s:0</div></div>
    <div class="stat-card"><div class="stat-label">Dot Balls</div><div class="stat-value" id="stat-dots">0</div><div class="stat-sub" id="stat-dot-pct">0%</div></div>
    <div class="stat-card"><div class="stat-label">Overs Left</div><div class="stat-value" id="stat-overs-left">—</div><div class="stat-sub" id="stat-balls-left">balls left</div></div>
    <div class="stat-card"><div class="stat-label">Extras</div><div class="stat-value" id="stat-extras">0</div><div class="stat-sub" id="stat-extras-sub">W:0 NB:0 B:0</div></div>
    <div class="stat-card" style="grid-column:span 2"><div class="stat-label">Top Bowler</div><div class="stat-value" style="font-size:1.2rem" id="stat-top-bowler">—</div><div class="stat-sub" id="stat-top-bowler-sub">no overs yet</div></div>
    <div class="stat-card" style="grid-column:span 2"><div class="stat-label">Top Scorer</div><div class="stat-value" style="font-size:1.2rem" id="stat-top-bat">—</div><div class="stat-sub" id="stat-top-bat-sub">no balls faced</div></div>
  </div>
</div>

<!-- HISTORY TAB -->
<div class="tab-content" id="tab-history">
  <div class="history-header">
    <div class="section-title">🗂 MATCH HISTORY</div>
    <button class="btn-clear-hist" onclick="clearHistory()">🗑 Clear All</button>
  </div>
  <div class="history-content" id="history-list">
    <div class="empty-state"><div class="icon">🗂</div>No saved matches yet.<br>Finish a match to save it here.</div>
  </div>
</div>

<!-- SETUP TAB -->
<div class="tab-content" id="tab-setup">
  <div class="setup-content">
    <div class="setup-group"><div class="setup-label">BATTING TEAM</div><input type="text" id="team-bat" value="Chennai Sydney Kings"></div>
    <div class="setup-group"><div class="setup-label">BOWLING TEAM</div><input type="text" id="team-field" value="Opponents"></div>
    <div class="setup-divider"></div>
    <div class="setup-group"><div class="setup-label">OPENING BATSMAN 1</div><input type="text" id="opener1" placeholder="e.g. Arun"></div>
    <div class="setup-group"><div class="setup-label">OPENING BATSMAN 2</div><input type="text" id="opener2" placeholder="e.g. Kavin"></div>
    <div class="setup-divider"></div>
    <div class="setup-group"><div class="setup-label">TOTAL OVERS</div><input type="number" id="total-overs" value="10" min="1" max="50"></div>
    <div class="setup-group"><div class="setup-label">BALLS PER OVER</div>
      <select id="balls-per-over"><option value="6" selected>6 balls</option><option value="5">5 balls</option><option value="4">4 balls</option><option value="8">8 balls</option></select>
    </div>
    <div class="setup-group"><div class="setup-label">MAX WICKETS</div><input type="number" id="max-wickets" value="10" min="1" max="10"></div>
    <div class="setup-group"><div class="setup-label">TARGET (2nd innings)</div><input type="number" id="target-runs" placeholder="e.g. 120" min="0"></div>
    <div style="background:rgba(245,158,11,0.07);border:1px solid rgba(245,158,11,0.2);border-radius:10px;padding:10px 12px;font-size:0.72rem;color:var(--amber);">
      💡 <strong>Update Settings</strong> applies changes mid-game without resetting scores.<br>
      Use <strong>Apply &amp; Start</strong> only to begin a brand new match.
    </div>
    <button class="btn-update-settings" onclick="updateSettings()">✏️ UPDATE SETTINGS</button>
    <button class="btn-apply" onclick="applySetup()">✔ APPLY & START NEW MATCH</button>
    <button class="btn-reset-m" onclick="confirmReset()">🔄 RESET MATCH</button>
  </div>
</div>

<!-- End Innings Overlay (1st innings complete) -->
<div class="end-innings-overlay" id="end-innings-overlay">
  <div class="end-innings-card">
    <div class="ei-icon">🏏</div>
    <h2>1ST INNINGS COMPLETE</h2>
    <div class="ei-score" id="ei-score">0/0</div>
    <div class="ei-meta" id="ei-meta">in 0 overs · Target: 1</div>
    <button class="btn-start-2nd" onclick="startSecondInnings()">▶ START 2ND INNINGS</button>
    <button class="btn-new-from-ei" onclick="confirmReset()">🔄 Start New Match Instead</button>
  </div>
</div>

<!-- Match Complete -->
<div class="complete-overlay" id="complete-overlay">
  <div class="complete-card">
    <div class="trophy">🏆</div>
    <h2>INNINGS OVER</h2>
    <div class="final-score" id="final-score">0/0</div>
    <div class="final-meta" id="final-meta">in 0 overs</div>
    <button class="btn-new-match" onclick="confirmReset()">🔄 NEW MATCH</button>
  </div>
</div>

<!-- New Batsman Modal -->
<div class="modal-overlay" id="new-batsman-modal">
  <div class="modal-card">
    <h3>🏏 WICKET!</h3>
    <p id="modal-msg">Enter the new batsman's name</p>
    <input type="text" id="new-batsman-input" placeholder="New batsman name..." autocomplete="off" autocorrect="off">
    <button class="btn-confirm" onclick="confirmNewBatsman()">COME IN TO BAT →</button>
  </div>
</div>

<!-- Match Detail Modal -->
<div class="hist-modal-overlay" id="hist-modal">
  <div class="hist-modal-header">
    <span class="hist-modal-title" id="hist-modal-title">MATCH DETAILS</span>
    <button class="btn-hist-close" onclick="closeHistModal()">✕ CLOSE</button>
  </div>
  <div class="hist-modal-inner" id="hist-modal-inner"></div>
</div>

<!-- Recall Retired Batsman Modal -->
<div class="recall-modal-overlay" id="recall-modal">
  <div class="recall-modal-card">
    <div class="recall-modal-title" id="recall-modal-title">Recall Batsman</div>
    <div class="recall-modal-sub">Who does this batsman replace at the crease?</div>
    <div class="recall-choice-grid">
      <button class="btn-recall-choice" onclick="recallAs('striker')">
        <span class="rchoice-role">🏏 Striker</span>
        <span class="rchoice-name" id="recall-striker-name">—</span>
        <span style="font-size:0.62rem;color:rgba(74,222,128,0.7);margin-top:4px;display:block">goes to retired</span>
      </button>
      <button class="btn-recall-choice" onclick="recallAs('nonstriker')">
        <span class="rchoice-role">Non-Striker</span>
        <span class="rchoice-name" id="recall-nonstriker-name">—</span>
        <span style="font-size:0.62rem;color:rgba(74,222,120,0.7);margin-top:4px;display:block">goes to retired</span>
      </button>
    </div>
    <button class="btn-ecancel" onclick="document.getElementById('recall-modal').classList.remove('show')">✕ Cancel</button>
  </div>
</div>

<!-- Wide / NB + Runs Modal -->
<div class="extras-modal-overlay" id="extras-modal">
  <div class="extras-modal-card" id="extras-modal-card">
    <div class="extras-modal-title" id="extras-modal-title">WIDE</div>
    <div class="extras-modal-sub">How many runs were scored off this delivery?</div>
    <div class="extras-run-grid">
      <button class="btn-erun" onclick="scoreExtras(0)">0<br><span style="font-size:0.5rem;font-family:'DM Sans',sans-serif;opacity:0.7">runs</span></button>
      <button class="btn-erun" onclick="scoreExtras(1)">1<br><span style="font-size:0.5rem;font-family:'DM Sans',sans-serif;opacity:0.7">run</span></button>
      <button class="btn-erun" onclick="scoreExtras(2)">2<br><span style="font-size:0.5rem;font-family:'DM Sans',sans-serif;opacity:0.7">runs</span></button>
      <button class="btn-erun" onclick="scoreExtras(3)">3<br><span style="font-size:0.5rem;font-family:'DM Sans',sans-serif;opacity:0.7">runs</span></button>
      <button class="btn-erun" onclick="scoreExtras(4)">4<br><span style="font-size:0.5rem;font-family:'DM Sans',sans-serif;opacity:0.7">runs</span></button>
    </div>
    <button class="btn-ecancel" onclick="closeExtrasModal()">✕ Cancel</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const STORAGE_KEY='cricket-live-v2';
const HISTORY_KEY='cricket-history-v1';
const POLL_MS=3000;
let isScorer=false, pollTimer=null;

// ── CLOUDFLARE KV API ─────────────────────────────────
// Worker is deployed at /api — same origin as the HTML.
// Falls back gracefully to localStorage if Worker is unreachable.
const KV={
  async get(key){
    try{
      const r=await fetch(`/api/kv/${encodeURIComponent(key)}`);
      if(!r.ok) throw new Error('not found');
      const j=await r.json();
      return j.value??null;
    }catch(e){
      // localStorage fallback
      return localStorage.getItem(key);
    }
  },
  async set(key,value){
    try{
      const r=await fetch(`/api/kv/${encodeURIComponent(key)}`,{
        method:'PUT',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({value})
      });
      if(!r.ok) throw new Error('write failed');
      return true;
    }catch(e){
      localStorage.setItem(key,value);
      return false; // offline fallback
    }
  },
  async del(key){
    try{
      await fetch(`/api/kv/${encodeURIComponent(key)}`,{method:'DELETE'});
    }catch(e){
      localStorage.removeItem(key);
    }
  }
};

// ── STATE ─────────────────────────────────────────────
function fresh(){
  return {
    runs:0,wickets:0,currentBalls:[],legalBalls:0,
    overs:[],extras:{wides:0,nb:0,byes:0},
    fours:0,sixes:0,dots:0,totalLegalBalls:0,
    maxOvers:10,bpo:6,maxWickets:10,
    target:null,matchOver:false,bowler:'',
    inningsNum:1,        // 1 = first innings, 2 = second innings
    innings1:null,       // snapshot saved after 1st innings ends
    // Batting
    batsmen:[],      // array of {name, runs, balls, fours, sixes, out, outDesc}
    strikeIdx:0,     // index into batsmen[] of current striker
    nonStrikeIdx:1,  // index into batsmen[] of non-striker
    ts:Date.now()
  };
}
let S=fresh();

// ── STORAGE ───────────────────────────────────────────
async function save(){
  try{
    S.ts=Date.now();
    const ok=await KV.set(STORAGE_KEY,JSON.stringify(S));
    setSyncStatus(ok?'synced':'offline');
  }catch(e){setSyncStatus('offline');}
}
async function load(){
  try{
    const val=await KV.get(STORAGE_KEY);
    if(val){const rem=JSON.parse(val);if(rem.ts>S.ts){S=rem;renderAll();updateBattingCard();updateScorebookTable();}}
    setSyncStatus('synced');
  }catch(e){setSyncStatus('offline');}
}

// ── SYNC STATUS ───────────────────────────────────────
function setSyncStatus(s){
  const dot=document.getElementById('sync-dot'),lbl=document.getElementById('sync-label');
  dot.className='dot '+s;
  lbl.textContent=s==='synced'?(isScorer?'🟢 Live · Scoring':'🟢 Live · Watching'):s==='offline'?'🟡 Offline':'Syncing...';
}

// ── BATSMEN HELPERS ───────────────────────────────────
function striker(){return S.batsmen[S.strikeIdx]||null;}
function nonStriker(){return S.batsmen[S.nonStrikeIdx]||null;}

function addRunsToBatsman(runs, type){
  // Only credit runs to batsman for non-bye, non-wide
  if(['bye','wide','noball'].includes(type)) return;
  const b=striker();
  if(!b) return;
  b.runs+=runs;
  if(type==='4') b.fours++;
  if(type==='6') b.sixes++;
}

function chargeBallToBatsman(){
  // Legal balls faced (not wide, not nb without runs)
  const b=striker();
  if(b) b.balls++;
}

function swapStrike(){
  const tmp=S.strikeIdx; S.strikeIdx=S.nonStrikeIdx; S.nonStrikeIdx=tmp;
}

function shouldSwap(runs, type){
  // Wides and no balls: no swap
  if(type==='wide'||type==='noball') return false;
  // Odd runs = swap (includes byes)
  return runs%2===1;
}

// ── WICKET / NEW BATSMAN ──────────────────────────────
let pendingWicketCallback=null;

function promptNewBatsman(outName, callback){
  const isRetire = outName.includes('Retired');
  document.getElementById('modal-msg').textContent = isRetire
    ? `${outName}. Who's coming in?`
    : `${outName} is OUT! Who's coming in?`;
  document.getElementById('new-batsman-input').value='';
  document.getElementById('new-batsman-modal').classList.add('show');
  setTimeout(()=>document.getElementById('new-batsman-input').focus(),200);
  pendingWicketCallback=callback;
}

function confirmNewBatsman(){
  const name=document.getElementById('new-batsman-input').value.trim();
  if(!name){showToast('Enter a name!');return;}
  document.getElementById('new-batsman-modal').classList.remove('show');
  if(pendingWicketCallback){pendingWicketCallback(name);pendingWicketCallback=null;}
}

// ── EXTRAS MODAL (Wide + Runs / NB + Runs) ────────────────────────────────
let _extrasType = null;
function openExtrasModal(type) {
  if(!isScorer){showToast('Tap "Take Over" to score');return;}
  if(S.matchOver) return;
  _extrasType = type;
  const card = document.getElementById('extras-modal-card');
  const title = document.getElementById('extras-modal-title');
  if(type === 'wide'){
    card.classList.remove('nb-mode');
    title.textContent = 'WIDE';
  } else {
    card.classList.add('nb-mode');
    title.textContent = 'NO BALL';
  }
  document.getElementById('extras-modal').classList.add('show');
}
function closeExtrasModal(){
  document.getElementById('extras-modal').classList.remove('show');
  _extrasType = null;
}
function scoreExtras(runs){
  const type = _extrasType;
  closeExtrasModal();
  if(!type || !isScorer || S.matchOver) return;
  S.bowler = document.getElementById('bowler-name').value.trim() || 'Unknown';

  const totalRuns = (type === 'wide' ? 1 : 1) + runs; // 1 penalty + extra runs
  let entry;
  if(type === 'wide'){
    S.extras.wides += (1 + runs);
    const label = runs > 0 ? `W+${runs}` : 'W';
    entry = {type:'wide', runs: 1 + runs, label, cssClass:'wide'};
  } else {
    S.extras.nb += (1 + runs);
    const label = runs > 0 ? `NB+${runs}` : 'NB';
    entry = {type:'noball', runs: 1 + runs, label, cssClass:'noball'};
    // NB runs scored by bat go to batsman
    if(runs > 0) addRunsToBatsman(runs, 'nb-runs');
  }
  S.runs += (1 + runs);
  // wides & noballs: not legal, no ball count change
  S.currentBalls.push(entry);

  // Check if target reached (2nd innings win)
  if(S.target && S.runs >= S.target){
    renderAll();updateBattingCard();save();endOver(true);endMatch();return;
  }

  if(S.wickets >= S.maxWickets){renderAll();updateBattingCard();save();endOver(true);endMatch();return;}
  renderAll();updateBattingCard();save();
}

// ── RETIRED OUT (toggle — retire or recall) ───────────────────────────────
function retireBatsman(idx){
  if(!isScorer){showToast('Take over scoring first');return;}
  if(S.matchOver) return;
  const bat = S.batsmen[idx];
  if(!bat) return;

  // ── RECALL: bat is already retired — bring them back ──────────────────
  if(bat.out && bat.outDesc === 'retired out'){
    // Need to replace one of the current active batsmen
    // Ask which position they're coming back to
    showRecallModal(idx);
    return;
  }

  // ── RETIRE: active bat leaves, new bat comes in ───────────────────────
  if(bat.out) return; // already out for another reason

  const wasStriker = (idx === S.strikeIdx);
  bat.out = true;
  bat.outDesc = 'retired out';
  // Do NOT increment S.wickets — retired is not a wicket

  renderAll();updateBattingCard();
  switchTab('score');

  promptNewBatsman(bat.name + ' — Retired', newName => {
    S.batsmen.push({name:newName, runs:0, balls:0, fours:0, sixes:0, out:false, outDesc:''});
    if(wasStriker){
      S.strikeIdx = S.batsmen.length - 1;
    } else {
      S.nonStrikeIdx = S.batsmen.length - 1;
    }
    renderAll();updateBattingCard();save();
    showToast(`${newName} comes in 🏏`);
  });
}

// ── RECALL MODAL ──────────────────────────────────────────────────────────
let _recallIdx = null;
function showRecallModal(retiredIdx){
  _recallIdx = retiredIdx;
  const bat = S.batsmen[retiredIdx];
  const striker = S.batsmen[S.strikeIdx];
  const nonStriker = S.batsmen[S.nonStrikeIdx];
  document.getElementById('recall-modal-title').textContent = `Recall ${bat.name}`;
  document.getElementById('recall-striker-name').textContent  = striker  ? striker.name  : '—';
  document.getElementById('recall-nonstriker-name').textContent = nonStriker ? nonStriker.name : '—';
  document.getElementById('recall-modal').classList.add('show');
}
function recallAs(position){
  // position: 'striker' or 'nonstriker'
  document.getElementById('recall-modal').classList.remove('show');
  if(_recallIdx === null) return;
  const bat = S.batsmen[_recallIdx];
  if(!bat) return;

  // The replaced batsman goes back to retired out
  if(position === 'striker'){
    const replaced = S.batsmen[S.strikeIdx];
    if(replaced){ replaced.out = true; replaced.outDesc = 'retired out'; }
    S.strikeIdx = _recallIdx;
  } else {
    const replaced = S.batsmen[S.nonStrikeIdx];
    if(replaced){ replaced.out = true; replaced.outDesc = 'retired out'; }
    S.nonStrikeIdx = _recallIdx;
  }

  bat.out = false;
  bat.outDesc = '';
  _recallIdx = null;

  renderAll();updateBattingCard();save();
  showToast(`${bat.name} recalled! 🏏`);
}

function tryTakeOver(){
  const overlay=document.getElementById('spectator-overlay');
  if(overlay) overlay.style.display='flex';
}
function takeOver(){
  try{
    isScorer=true;
    const overlay=document.getElementById('spectator-overlay');
    if(overlay) overlay.style.display='none';
    const b=document.getElementById('scorer-badge');
    if(b){
      b.className='scorer-badge is-scorer';
      b.textContent='✏️ YOU ARE SCORING';
      b.onclick=surrender;
    }
    stopPoll();
    setSyncStatus('synced');
    showToast('You are now scoring! 🏏');
    renderAll(); // Refresh UI to show scorer-only elements
  }catch(e){
    console.error('takeOver error:',e);
    showToast('Error taking over - refresh page');
  }
}
function surrender(){
  if(!confirm('Hand scoring back?')) return;
  isScorer=false;
  const b=document.getElementById('scorer-badge');
  if(b){
    b.className='scorer-badge is-watcher';
    b.textContent='👁 WATCHING — Tap to Score';
    b.onclick=tryTakeOver;
  }
  startPoll();
  showToast('Now watching live 👁');
  renderAll();
}
function watchOnly(){
  const overlay=document.getElementById('spectator-overlay');
  if(overlay) overlay.style.display='none';
  startPoll();
  showToast('Watching live 👁');
}

// ── POLLING ───────────────────────────────────────────
function startPoll(){stopPoll();pollTimer=setInterval(load,POLL_MS);}
function stopPoll(){if(pollTimer){clearInterval(pollTimer);pollTimer=null;}}

// ── TABS ─────────────────────────────────────────────
function switchTab(name){
  const names=['score','batting','book','stats','history','setup'];
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',names[i]===name));
  document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='stats') updateStats();
  if(name==='batting') updateBattingCard();
  if(name==='history') renderHistory();
  if(name==='setup') populateSetupFields();
}

// ── SCORE ─────────────────────────────────────────────
function score(type){
  if(!isScorer){showToast('Tap "Take Over" to score');return;}
  if(S.matchOver) return;
  S.bowler=document.getElementById('bowler-name').value.trim()||'Unknown';

  let runs=0,legal=true,entry;
  switch(type){
    case 'dot':    entry={type,runs:0,label:'•',cssClass:'dot'};   S.dots++;S.totalLegalBalls++;chargeBallToBatsman();break;
    case '1':      runs=1;entry={type,runs:1,label:'1',cssClass:'run1'};S.totalLegalBalls++;chargeBallToBatsman();break;
    case '2':      runs=2;entry={type,runs:2,label:'2',cssClass:'run2'};S.totalLegalBalls++;chargeBallToBatsman();break;
    case '3':      runs=3;entry={type,runs:3,label:'3',cssClass:'run3'};S.totalLegalBalls++;chargeBallToBatsman();break;
    case '4':      runs=4;entry={type,runs:4,label:'4',cssClass:'run4'};S.fours++;S.totalLegalBalls++;chargeBallToBatsman();break;
    case '6':      runs=6;entry={type,runs:6,label:'6',cssClass:'run6'};S.sixes++;S.totalLegalBalls++;chargeBallToBatsman();break;
    case 'wide':   runs=1;legal=false;entry={type,runs:1,label:'W',cssClass:'wide'};S.extras.wides++;break;
    case 'nb':     runs=1;legal=false;entry={type:'noball',runs:1,label:'NB',cssClass:'noball'};S.extras.nb++;break;
    case '1b':     runs=1;entry={type:'bye',runs:1,label:'1b',cssClass:'bye'};S.extras.byes+=1;S.totalLegalBalls++;chargeBallToBatsman();break;
    case '2b':     runs=2;entry={type:'bye',runs:2,label:'2b',cssClass:'bye'};S.extras.byes+=2;S.totalLegalBalls++;chargeBallToBatsman();break;
    case '3b':     runs=3;entry={type:'bye',runs:3,label:'3b',cssClass:'bye'};S.extras.byes+=3;S.totalLegalBalls++;chargeBallToBatsman();break;
    case 'wicket':
      entry={type,runs:0,label:'W!',cssClass:'wicket'};
      S.totalLegalBalls++;chargeBallToBatsman();
      // Mark batsman out
      const outBat=striker();
      if(outBat){outBat.out=true;outBat.outDesc=`b. ${S.bowler}`;}
      S.wickets++;S.runs+=runs;
      if(legal) S.legalBalls++;
      S.currentBalls.push(entry);
      // Check all out
      if(S.wickets>=S.maxWickets){renderAll();updateBattingCard();save();endOver(true);endMatch();return;}
      // Prompt new batsman
      renderAll();updateBattingCard();save();
      promptNewBatsman(outBat?outBat.name:'Batsman', newName=>{
        S.batsmen.push({name:newName,runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''});
        S.strikeIdx=S.batsmen.length-1;
        // swap after odd runs handled by wicket (0 runs = no swap needed, new bat takes strike)
        renderAll();updateBattingCard();save();
      });
      return;
  }

  // Add runs to batsman (non-wicket)
  addRunsToBatsman(runs, type);

  S.runs+=runs;
  if(legal) S.legalBalls++;
  S.currentBalls.push(entry);

  // Check if target reached (2nd innings win)
  if(S.target && S.runs >= S.target){
    renderAll();updateBattingCard();save();endOver(true);endMatch();return;
  }

  // Swap strike based on runs
  if(shouldSwap(runs,type)) swapStrike();

  if(S.wickets>=S.maxWickets){renderAll();updateBattingCard();save();endOver(true);endMatch();return;}
  if(S.legalBalls>=S.bpo) endOver(true);

  renderAll();updateBattingCard();save();
}

// ── END OVER ─────────────────────────────────────────
function endOver(auto=false){
  if(!isScorer&&!auto){showToast('Take over scoring first');return;}
  if(S.currentBalls.length===0&&!auto){showToast('No balls bowled yet!');return;}
  if(S.currentBalls.length===0) return;
  const overRuns=S.currentBalls.reduce((a,b)=>a+b.runs,0);
  const overWkts=S.currentBalls.filter(b=>b.type==='wicket').length;
  S.overs.push({n:S.overs.length+1,bowler:S.bowler,balls:[...S.currentBalls],runs:overRuns,wickets:overWkts,score:`${S.runs}/${S.wickets}`});
  S.currentBalls=[];S.legalBalls=0;
  // End of over: always swap strike
  swapStrike();
  document.getElementById('bowler-name').value='';
  renderAll();updateBattingCard();updateScorebookTable();save();
  showToast(`Over ${S.overs.length} done — ${overRuns} runs`);
  if(S.overs.length>=S.maxOvers) endMatch();
}

// ── UNDO ─────────────────────────────────────────────
function undoLast(){
  if(!isScorer){showToast('Take over scoring first');return;}
  if(S.matchOver) return;
  if(S.currentBalls.length===0){
    if(S.overs.length===0) return;
    const last=S.overs.pop();
    S.runs-=last.runs;S.wickets-=last.wickets;
    S.currentBalls=last.balls;
    S.legalBalls=last.balls.filter(b=>!['wide','noball'].includes(b.type)).length;
    document.getElementById('bowler-name').value=last.bowler;
    swapStrike(); // undo the end-of-over swap
    renderAll();updateBattingCard();updateScorebookTable();save();
    showToast('Restored over '+last.n);return;
  }
  const b=S.currentBalls.pop();S.runs-=b.runs;
  // Reverse strike if it was swapped
  if(shouldSwap(b.runs,b.type)) swapStrike();
  if(b.type==='wicket'){
    // Restore batsman
    S.wickets--;
    const last=S.batsmen[S.batsmen.length-1];
    if(last&&!last.out) S.batsmen.pop(); // remove new batsman
    const prev=striker(); if(prev){prev.out=false;prev.outDesc='';}
  }
  if(b.type==='wide')  S.extras.wides--;
  if(b.type==='noball')S.extras.nb--;
  if(b.type==='bye')   S.extras.byes-=b.runs;
  if(b.type==='4')     S.fours--;
  if(b.type==='6')     S.sixes--;
  if(b.type==='dot')   S.dots--;
  // Reverse batsman stats
  const bat=striker();
  if(bat&&!['wide','noball','bye'].includes(b.type)){
    bat.runs-=b.runs;
    if(b.type==='4') bat.fours--;
    if(b.type==='6') bat.sixes--;
  }
  const wasLegal=!['wide','noball'].includes(b.type);
  if(wasLegal){S.legalBalls=Math.max(0,S.legalBalls-1);S.totalLegalBalls=Math.max(0,S.totalLegalBalls-1);if(bat) bat.balls=Math.max(0,bat.balls-1);}
  renderAll();updateBattingCard();save();showToast('Last ball undone');
}

// ── END MATCH ─────────────────────────────────────────
function endMatch(){
  S.matchOver=true;
  const ov=S.overs.length,bl=S.totalLegalBalls%S.bpo;

  // Enhanced final score display for target chases
  let finalScoreText = `${S.runs}/${S.wickets}`;
  let finalMetaText = `in ${bl>0?ov+'.'+bl:ov} overs · RR: ${calcRR()}`;

  if(S.inningsNum===1){
    // 1st innings ended by overs/wickets — trigger innings transition
    _doEndInnings();
    return;
  }

  // 2nd innings final
  if(S.target && S.runs >= S.target){
    const wicketsLeft = S.maxWickets - S.wickets;
    const ballsLeft = (S.maxOvers - ov) * S.bpo - S.legalBalls;
    finalScoreText = `🏆 WON BY ${wicketsLeft} WICKET${wicketsLeft !== 1 ? 'S' : ''}`;
    finalMetaText = `${S.runs}/${S.wickets} in ${bl>0?ov+'.'+bl:ov} overs · ${ballsLeft} ball${ballsLeft !== 1 ? 's' : ''} left`;
  } else if(S.target){
    const margin = S.target - S.runs - 1;
    finalScoreText = `❌ LOST BY ${margin} RUN${margin!==1?'S':''}`;
    finalMetaText = `${S.runs}/${S.wickets} in ${bl>0?ov+'.'+bl:ov} overs`;
  }

  document.getElementById('final-score').textContent=finalScoreText;
  document.getElementById('final-meta').textContent=finalMetaText;
  document.getElementById('complete-overlay').classList.add('show');

  // Archive 2nd innings
  const teamBat=document.getElementById('team-bat').value.trim()||'Team A';
  const teamField=document.getElementById('team-field').value.trim()||'Team B';
  _archiveInnings({
    runs:S.runs,wickets:S.wickets,
    overs:S.overs,batsmen:S.batsmen,
    extras:S.extras,fours:S.fours,sixes:S.sixes,dots:S.dots,
    totalLegalBalls:S.totalLegalBalls,
    maxOvers:S.maxOvers,bpo:S.bpo,rr:calcRR()
  }, teamBat, teamField, S.target);

  save();
}

// ── END INNINGS (1st innings → save → start 2nd) ──────
function endInnings(){
  if(!isScorer){showToast('Take over scoring first');return;}
  if(S.inningsNum !== 1){showToast('Already in 2nd innings');return;}
  if(S.runs===0&&S.overs.length===0){showToast('No balls bowled yet!');return;}
  if(!confirm('End 1st innings and start 2nd? This will save 1st innings to History.')) return;
  _doEndInnings();
}

function _doEndInnings(){
  // Flush current incomplete over into overs list so it's saved
  if(S.currentBalls.length > 0) endOver(true);

  // Save 1st innings snapshot
  const teamBat = document.getElementById('team-bat').value.trim()||'Team A';
  const teamField = document.getElementById('team-field').value.trim()||'Team B';
  S.innings1 = {
    runs: S.runs, wickets: S.wickets,
    overs: JSON.parse(JSON.stringify(S.overs)),
    batsmen: JSON.parse(JSON.stringify(S.batsmen)),
    extras: {...S.extras},
    fours: S.fours, sixes: S.sixes, dots: S.dots,
    totalLegalBalls: S.totalLegalBalls,
    maxOvers: S.maxOvers, bpo: S.bpo,
    teamBat, teamField,
    rr: calcRR(),
  };

  // Archive 1st innings to History
  _archiveInnings(S.innings1, teamBat, teamField, null);

  // Show End Innings overlay
  const ov = S.overs.length, bl = S.totalLegalBalls % S.bpo;
  const target = S.runs + 1;
  document.getElementById('ei-score').textContent = `${S.runs}/${S.wickets}`;
  document.getElementById('ei-meta').textContent =
    `in ${bl>0?ov+'.'+bl:ov} overs · RR: ${S.innings1.rr}\nTarget for 2nd innings: ${target}`;
  document.getElementById('end-innings-overlay').classList.add('show');
  save();
}

async function _archiveInnings(inn, teamBat, teamField, targetRuns){
  try{
    let hist=[];
    try{const v=await KV.get(HISTORY_KEY);if(v)hist=JSON.parse(v);}catch(e){}
    const ov=inn.overs.length, bl=inn.totalLegalBalls%inn.bpo;
    const record={
      id:Date.now(), ts:Date.now(),
      teamBat, teamField,
      runs:inn.runs, wickets:inn.wickets,
      overs:`${bl>0?ov+'.'+bl:ov}`,
      maxOvers:inn.maxOvers, bpo:inn.bpo,
      rr:inn.rr,
      target:targetRuns,
      extras:inn.extras,
      fours:inn.fours, sixes:inn.sixes, dots:inn.dots,
      batsmen:inn.batsmen,
      overBook:inn.overs,
      inningsLabel: targetRuns ? '2nd Innings' : '1st Innings',
    };
    hist.unshift(record);
    if(hist.length>50) hist=hist.slice(0,50);
    await KV.set(HISTORY_KEY,JSON.stringify(hist));
  }catch(e){console.warn('Innings archive failed',e);}
}

function startSecondInnings(){
  document.getElementById('end-innings-overlay').classList.remove('show');
  document.getElementById('complete-overlay').classList.remove('show');

  const inn1 = S.innings1;
  if(!inn1){showToast('No 1st innings data!');return;}
  const target = inn1.runs + 1;

  // Reset batting/bowling state, keep match settings + innings1 snapshot
  S.runs=0; S.wickets=0; S.currentBalls=[]; S.legalBalls=0;
  S.overs=[]; S.extras={wides:0,nb:0,byes:0};
  S.fours=0; S.sixes=0; S.dots=0; S.totalLegalBalls=0;
  S.bowler=''; S.matchOver=false;
  S.target = target;
  S.inningsNum = 2;

  // Set up openers from Setup fields for 2nd innings
  const o1=(document.getElementById('opener1').value.trim()||'Batsman 1');
  const o2=(document.getElementById('opener2').value.trim()||'Batsman 2');
  S.batsmen=[
    {name:o1,runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''},
    {name:o2,runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''},
  ];
  S.strikeIdx=0; S.nonStrikeIdx=1;

  document.getElementById('bowler-name').value='';
  document.getElementById('new-batsman-modal').classList.remove('show');

  renderAll(); updateBattingCard(); updateScorebookTable(true); save();
  switchTab('score');
  showToast(`🏏 2nd innings — need ${target} to win!`);
}

function populateSetupFields(){
  // Pre-fill current match settings so scorer sees live values
  document.getElementById('total-overs').value   = S.maxOvers;
  document.getElementById('max-wickets').value   = S.maxWickets;
  document.getElementById('target-runs').value   = S.target || '';
  // Set the balls-per-over dropdown
  const bpoSel = document.getElementById('balls-per-over');
  for(let i=0;i<bpoSel.options.length;i++){
    if(parseInt(bpoSel.options[i].value)===S.bpo){ bpoSel.selectedIndex=i; break; }
  }
}

function applySetup(){
  if((S.runs>0||S.overs.length>0)&&!confirm('This will RESET the match and all scores. Are you sure?')) return;
  doReset();showToast('Match started!');switchTab('score');
}
function confirmReset(){if(confirm('Reset match for everyone?')) doReset();}

function updateSettings(){
  if(!isScorer){showToast('Take over scoring first');return;}
  const newOvers  = parseInt(document.getElementById('total-overs').value)||10;
  const newBpo    = parseInt(document.getElementById('balls-per-over').value)||6;
  const newWkts   = parseInt(document.getElementById('max-wickets').value)||10;
  const tval      = parseInt(document.getElementById('target-runs').value);
  const newTarget = isNaN(tval)||tval<=0 ? null : tval;

  // Warn if reducing overs below overs already bowled
  if(newOvers < S.overs.length){
    showToast(`⚠️ Can't set overs below ${S.overs.length} (already bowled)`);return;
  }

  S.maxOvers   = newOvers;
  S.bpo        = newBpo;
  S.maxWickets = newWkts;
  S.target     = newTarget;

  renderAll();updateBattingCard();save();
  showToast('✅ Settings updated!');
  switchTab('score');
}

async function doReset(){
  S=fresh();
  S.maxOvers  =parseInt(document.getElementById('total-overs').value)||10;
  S.bpo       =parseInt(document.getElementById('balls-per-over').value)||6;
  S.maxWickets=parseInt(document.getElementById('max-wickets').value)||10;
  const t=parseInt(document.getElementById('target-runs').value);
  S.target=isNaN(t)?null:t;
  // Set up openers
  const o1=(document.getElementById('opener1').value.trim()||'Batsman 1');
  const o2=(document.getElementById('opener2').value.trim()||'Batsman 2');
  S.batsmen=[
    {name:o1,runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''},
    {name:o2,runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''},
  ];
  S.strikeIdx=0;S.nonStrikeIdx=1;
  document.getElementById('complete-overlay').classList.remove('show');
  document.getElementById('end-innings-overlay').classList.remove('show');
  document.getElementById('bowler-name').value='';
  document.getElementById('new-batsman-modal').classList.remove('show');
  renderAll();updateBattingCard();updateScorebookTable(true);await save();
}

// ── HELPERS ───────────────────────────────────────────
function calcRR(){const o=S.overs.length+(S.legalBalls/S.bpo);return o>0?(S.runs/o).toFixed(2):'0.00';}
function totalExtras(){return S.extras.wides+S.extras.nb+S.extras.byes;}
function calcSR(runs,balls){return balls>0?((runs/balls)*100).toFixed(0):'—';}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}

// ── RENDER HEADER + BATSMEN BAR ───────────────────────
function renderAll(){
  document.getElementById('hdr-runs').textContent=S.runs;
  document.getElementById('hdr-wkts').textContent=S.wickets;
  const ov=S.overs.length,bl=S.legalBalls;
  document.getElementById('hdr-meta').textContent=`${bl>0?ov+'.'+bl:ov} ov · RR: ${calcRR()}`;

  // ── Innings banner (2nd innings only) ─────────────
  const banner=document.getElementById('innings-banner');
  const bannerLabel=document.getElementById('innings-banner-label');
  const bannerMeta=document.getElementById('innings-banner-meta');
  if(S.inningsNum===2 && S.innings1 && S.target){
    banner.classList.add('show');
    bannerLabel.textContent=`INN 2 · Target: ${S.target}`;
    const runsNeeded=Math.max(0,S.target-S.runs);
    const ballsLeft=Math.max(0,(S.maxOvers-ov)*S.bpo-bl);
    bannerMeta.textContent=`Need ${runsNeeded} from ${ballsLeft} balls`;
  } else {
    banner.classList.remove('show');
  }

  // Batsmen bar
  const b0=S.batsmen[S.strikeIdx], b1=S.batsmen[S.nonStrikeIdx];
  if(b0){
    document.getElementById('bat0-name').textContent=b0.name;
    document.getElementById('bat0-runs').textContent=b0.runs;
    document.getElementById('bat0-balls').textContent=b0.balls;
    document.getElementById('bat0-fours').textContent=b0.fours;
    document.getElementById('bat0-sixes').textContent=b0.sixes;
    document.getElementById('bat0-retire').innerHTML=isScorer&&!b0.out?`<button class="btn-retire" onclick="retireBatsman(${S.strikeIdx})">🚶 Retire</button>`:'';
  }
  if(b1){
    document.getElementById('bat1-name').textContent=b1.name;
    document.getElementById('bat1-runs').textContent=b1.runs;
    document.getElementById('bat1-balls').textContent=b1.balls;
    document.getElementById('bat1-fours').textContent=b1.fours;
    document.getElementById('bat1-sixes').textContent=b1.sixes;
    document.getElementById('bat1-retire').innerHTML=isScorer&&!b1.out?`<button class="btn-retire" onclick="retireBatsman(${S.nonStrikeIdx})">🚶 Retire</button>`:'';
  }

  // Ball strip
  const strip=document.getElementById('ball-strip');
  const lbl=`<span class="ball-strip-label">Ov ${ov+1} · B ${bl+1}</span>`;
  if(S.currentBalls.length===0){
    strip.innerHTML=lbl+`<span style="color:var(--muted);font-size:0.7rem;margin-left:6px">${isScorer?'Tap to score...':'Watching...'}</span>`;
  }else{
    const balls=S.currentBalls.map(b=>`<div class="ball-dot ${b.cssClass}">${b.label}</div>`).join('');
    const ph=Array(Math.max(0,S.bpo-S.legalBalls)).fill('<div class="ball-placeholder"></div>').join('');
    strip.innerHTML=lbl+balls+ph;
  }

  // ── Undo strip (scorer only, after a ball is bowled, before next) ─
  const undoStrip=document.getElementById('undo-strip');
  const undoDesc=document.getElementById('undo-last-desc');
  if(isScorer && S.currentBalls.length>0 && !S.matchOver){
    const last=S.currentBalls[S.currentBalls.length-1];
    const desc=last.type==='wicket'?'🔴 WICKET':
               last.type==='wide'?`Wide (+${last.runs}r)`:
               last.type==='noball'?`No Ball (+${last.runs}r)`:
               last.type==='bye'?`${last.runs} Bye${last.runs>1?'s':''}`:
               last.runs===0?'Dot ball':
               last.runs===4?'FOUR 🏏':
               last.runs===6?'SIX 🏏':
               `${last.runs} run${last.runs>1?'s':''}`;
    undoDesc.textContent=`Last: ${desc}`;
    undoStrip.classList.add('show');
  } else {
    undoStrip.classList.remove('show');
  }

  // Extras
  document.getElementById('ext-wides').textContent=S.extras.wides;
  document.getElementById('ext-nb').textContent=S.extras.nb;
  document.getElementById('ext-byes').textContent=S.extras.byes;
  document.getElementById('ext-total').textContent=totalExtras();
  if(S.matchOver) document.getElementById('complete-overlay').classList.add('show');
  if(S.inningsNum===1&&S.matchOver) document.getElementById('end-innings-overlay').classList.remove('show');

  // Hide/show "End 1st Innings" button based on innings number
  const eiBtn = document.querySelector('.btn-span2[onclick="endInnings()"]');
  if(eiBtn) eiBtn.style.display = (S.inningsNum===2||!isScorer) ? 'none' : '';
}

// ── BATTING SCORECARD ─────────────────────────────────
function updateBattingCard(){
  if(S.batsmen.length===0){
    document.getElementById('batting-empty').style.display='';
    document.getElementById('batting-table').style.display='none';
    return;
  }
  document.getElementById('batting-empty').style.display='none';
  document.getElementById('batting-table').style.display='';
  const body=document.getElementById('batting-body');
  body.innerHTML='';
  S.batsmen.forEach((bat,i)=>{
    const isStrike=i===S.strikeIdx&&!bat.out;
    const isNonStrike=i===S.nonStrikeIdx&&!bat.out;
    const sr=calcSR(bat.runs,bat.balls);
    const srClass=sr==='—'?'':parseInt(sr)>=100?'sr-good':parseInt(sr)>=60?'sr-ok':'sr-slow';
    const tr=document.createElement('tr');
    if(bat.out && bat.outDesc !== 'retired out') tr.className='out-row';
    const retireBtn = isScorer ? `<button class="btn-retire" onclick="retireBatsman(${i})">Retire</button>` : '';
    const recallBtn = isScorer ? `<button class="btn-retire" style="color:#4ade80;border-color:rgba(74,222,128,0.4);background:rgba(74,222,128,0.1)" onclick="retireBatsman(${i})">↩ Recall</button>` : '';
    const isRetired = bat.out && bat.outDesc === 'retired out';
    const statusBadge = isRetired
      ? `<span style="color:var(--amber);font-size:0.6rem">retired</span><br>${recallBtn}`
      : bat.out
        ? `<span class="out-badge">out</span>${bat.outDesc?'<br><span style="font-size:0.6rem;color:var(--muted)">'+bat.outDesc+'</span>':''}`
        : isStrike
          ? `<span style="color:var(--amber)">🏏 *</span>${retireBtn}`
          : isNonStrike
            ? `<span style="color:var(--muted)">non-str</span>${retireBtn}`
            : '<span style="color:var(--muted)">—</span>';
    tr.innerHTML=`
      <td class="name-col">${bat.name}</td>
      <td class="runs-col">${bat.runs}</td>
      <td class="muted-col">${bat.balls}</td>
      <td class="muted-col">${bat.fours}</td>
      <td class="muted-col">${bat.sixes}</td>
      <td class="${srClass}" style="font-family:'DM Mono',monospace;font-size:0.75rem;">${sr}</td>
      <td>${statusBadge}</td>`;
    body.appendChild(tr);
  });
}

// ── SCOREBOOK ─────────────────────────────────────────
function updateScorebookTable(reset=false){
  if(reset){document.getElementById('book-empty').style.display='';document.getElementById('book-table').style.display='none';document.getElementById('book-body').innerHTML='';return;}
  if(S.overs.length===0) return;
  document.getElementById('book-empty').style.display='none';
  document.getElementById('book-table').style.display='';
  const body=document.getElementById('book-body');
  body.innerHTML='';
  S.overs.forEach(o=>{
    const bh=o.balls.map(b=>`<div class="mini-ball ${b.cssClass}">${b.label}</div>`).join('');
    const tr=document.createElement('tr');
    tr.innerHTML=`<td style="color:var(--muted)">${o.n}</td><td class="name-col">${o.bowler}</td><td><div class="ball-seq">${bh}</div></td><td class="runs-col">${o.runs}</td><td class="wkts-col">${o.wickets||'—'}</td><td class="score-col">${o.score}</td>`;
    body.appendChild(tr);
  });
}

// ── STATS ─────────────────────────────────────────────
function updateStats(){
  document.getElementById('stat-rr').textContent=calcRR();
  const r=(()=>{if(!S.target)return null;const bl=S.overs.length*S.bpo+S.legalBalls,left=S.maxOvers*S.bpo-bl;return left>0?(((S.target-S.runs-1)/left)*S.bpo).toFixed(2):null;})();
  document.getElementById('stat-rrr').textContent=r||'—';
  document.getElementById('stat-rrr-sub').textContent=S.target?`need ${Math.max(0,S.target-S.runs)} from ${Math.max(0,(S.maxOvers-S.overs.length)*S.bpo-S.legalBalls)} balls`:'set target in setup';
  document.getElementById('stat-boundaries').textContent=S.fours+S.sixes;
  document.getElementById('stat-bound-sub').textContent=`4s:${S.fours} · 6s:${S.sixes}`;
  document.getElementById('stat-dots').textContent=S.dots;
  document.getElementById('stat-dot-pct').textContent=S.totalLegalBalls>0?`${Math.round(S.dots/S.totalLegalBalls*100)}% of balls`:'0%';
  const ol=Math.max(0,S.maxOvers-S.overs.length);
  document.getElementById('stat-overs-left').textContent=ol;
  document.getElementById('stat-balls-left').textContent=`${Math.max(0,ol*S.bpo-S.legalBalls)} balls left`;
  document.getElementById('stat-extras').textContent=totalExtras();
  document.getElementById('stat-extras-sub').textContent=`W:${S.extras.wides} NB:${S.extras.nb} B:${S.extras.byes}`;
  // Top bowler
  if(S.overs.length>0){
    const bm={};S.overs.forEach(o=>{if(!bm[o.bowler])bm[o.bowler]={runs:0,overs:0,wkts:0};bm[o.bowler].runs+=o.runs;bm[o.bowler].overs++;bm[o.bowler].wkts+=o.wickets;});
    const best=Object.entries(bm).sort((a,b)=>b[1].wkts-a[1].wkts||a[1].runs-b[1].runs)[0];
    document.getElementById('stat-top-bowler').textContent=best[0];
    document.getElementById('stat-top-bowler-sub').textContent=`${best[1].runs} runs · ${best[1].wkts} wkts · ${best[1].overs} ov`;
  }
  // Top batsman
  if(S.batsmen.length>0){
    const best=[...S.batsmen].sort((a,b)=>b.runs-a.runs)[0];
    document.getElementById('stat-top-bat').textContent=best.name;
    const sr=calcSR(best.runs,best.balls);
    document.getElementById('stat-top-bat-sub').textContent=`${best.runs} runs · ${best.balls} balls · SR: ${sr}`;
  }
}

// ── MATCH HISTORY ─────────────────────────────────────
// archiveMatch replaced by _archiveInnings() above — called by endMatch() and _doEndInnings()

async function loadHistory(){
  try{
    const v=await KV.get(HISTORY_KEY);
    if(v) return JSON.parse(v);
  }catch(e){}
  return [];
}

function fmtDate(ts){
  const d=new Date(ts);
  return d.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})
    +' '+d.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
}

async function renderHistory(){
  const hist=await loadHistory();
  const container=document.getElementById('history-list');
  if(!hist||hist.length===0){
    container.innerHTML='<div class="empty-state"><div class="icon">🗂</div>No saved matches yet.<br>Finish a match to save it here.</div>';
    return;
  }
  container.innerHTML=hist.map((m,idx)=>{
    const won=m.target&&m.runs>=m.target;
    const status=m.target?(won?'🏆 WIN':'❌ LOSS'):'📋 Innings';
    return `<div class="match-card" onclick="openHistMatch(${idx})">
      <div class="match-card-header">
        <div class="match-teams">${escHtml(m.teamBat)} vs ${escHtml(m.teamField)}</div>
        <div class="match-date">${fmtDate(m.ts)}</div>
      </div>
      <div class="match-score-line">${m.runs}/${m.wickets}</div>
      <div class="match-meta-row">
        <span class="match-chip">${m.overs}/${m.maxOvers} ov</span>
        <span class="match-chip">RR ${m.rr}</span>
        <span class="match-chip">4s:${m.fours} 6s:${m.sixes}</span>
        ${m.target?`<span class="match-chip ${won?'win':''}">${status} · T:${m.target}</span>`:`<span class="match-chip">${status}</span>`}
        ${m.inningsLabel?`<span class="match-chip" style="border-color:rgba(245,158,11,0.3);color:var(--amber)">${m.inningsLabel}</span>`:''}
      </div>
    </div>`;
  }).join('');
}

let _histCache=[];
async function openHistMatch(idx){
  _histCache=await loadHistory();
  const m=_histCache[idx];
  if(!m) return;
  document.getElementById('hist-modal-title').textContent=`${m.teamBat.toUpperCase()} vs ${m.teamField.toUpperCase()}`;
  const ov=m.overs;
  const won=m.target&&m.runs>=m.target;

  // Top scorer
  const topBat=m.batsmen&&m.batsmen.length?[...m.batsmen].sort((a,b)=>b.runs-a.runs)[0]:null;
  // Top bowler
  const bm={};
  (m.overBook||[]).forEach(o=>{
    if(!bm[o.bowler])bm[o.bowler]={runs:0,overs:0,wkts:0};
    bm[o.bowler].runs+=o.runs;bm[o.bowler].overs++;bm[o.bowler].wkts+=o.wickets;
  });
  const topBowlerEntry=Object.entries(bm).sort((a,b)=>b[1].wkts-a[1].wkts||a[1].runs-b[1].runs)[0];

  // Batting rows
  const batRows=(m.batsmen||[]).map(b=>{
    const sr=b.balls>0?((b.runs/b.balls)*100).toFixed(0):'—';
    const srCls=sr==='—'?'':parseInt(sr)>=100?'sr-good':parseInt(sr)>=60?'sr-ok':'sr-slow';
    return `<tr${b.out?' class="out-row"':''}>
      <td class="name-col">${escHtml(b.name)}${!b.out?'<span class="not-out-badge">*</span>':''}</td>
      <td class="runs-col">${b.runs}</td>
      <td class="muted-col">${b.balls}</td>
      <td class="muted-col">${b.fours}</td>
      <td class="muted-col">${b.sixes}</td>
      <td class="${srCls}" style="font-family:'DM Mono',monospace;font-size:0.75rem;">${sr}</td>
      <td>${b.out?`<span class="out-badge">out</span>`:'<span class="not-out-badge">n/o</span>'}</td>
    </tr>`;
  }).join('');

  // Scorebook rows
  const bookRows=(m.overBook||[]).map(o=>{
    const bh=(o.balls||[]).map(b=>`<div class="mini-ball ${b.cssClass}">${b.label}</div>`).join('');
    return `<tr>
      <td style="color:var(--muted)">${o.n}</td>
      <td class="name-col">${escHtml(o.bowler)}</td>
      <td><div class="ball-seq">${bh}</div></td>
      <td class="runs-col">${o.runs}</td>
      <td class="wkts-col">${o.wickets||'—'}</td>
      <td class="score-col">${o.score}</td>
    </tr>`;
  }).join('');

  document.getElementById('hist-modal-inner').innerHTML=`
    <div class="hist-big-score">${m.runs}/${m.wickets}</div>
    <div class="hist-teams-line">${escHtml(m.teamBat)} batting · ${ov}/${m.maxOvers} overs · RR ${m.rr}
      ${m.target?`<br>${won?'🏆 Won':'❌ Lost'} · Target: ${m.target}`:''}
    </div>

    <div class="stats-content" style="padding:0 0 8px">
      <div class="stat-card"><div class="stat-label">Run Rate</div><div class="stat-value">${m.rr}</div></div>
      <div class="stat-card"><div class="stat-label">Boundaries</div><div class="stat-value">${m.fours+m.sixes}</div><div class="stat-sub">4s:${m.fours} · 6s:${m.sixes}</div></div>
      <div class="stat-card"><div class="stat-label">Dots</div><div class="stat-value">${m.dots}</div></div>
      <div class="stat-card"><div class="stat-label">Extras</div><div class="stat-value">${(m.extras.wides||0)+(m.extras.nb||0)+(m.extras.byes||0)}</div><div class="stat-sub">W:${m.extras.wides||0} NB:${m.extras.nb||0} B:${m.extras.byes||0}</div></div>
      ${topBat?`<div class="stat-card" style="grid-column:span 2"><div class="stat-label">Top Scorer</div><div class="stat-value" style="font-size:1.2rem">${escHtml(topBat.name)}</div><div class="stat-sub">${topBat.runs} runs · ${topBat.balls} balls</div></div>`:''}
      ${topBowlerEntry?`<div class="stat-card" style="grid-column:span 2"><div class="stat-label">Top Bowler</div><div class="stat-value" style="font-size:1.2rem">${escHtml(topBowlerEntry[0])}</div><div class="stat-sub">${topBowlerEntry[1].runs} runs · ${topBowlerEntry[1].wkts} wkts · ${topBowlerEntry[1].overs} ov</div></div>`:''}
    </div>

    ${batRows?`<div class="hist-section">🏏 BATTING SCORECARD</div>
    <table><thead><tr><th>Batsman</th><th>R</th><th>B</th><th>4s</th><th>6s</th><th>SR</th><th></th></tr></thead>
    <tbody>${batRows}</tbody></table>`:''}

    ${bookRows?`<div class="hist-section">📋 OVER BY OVER</div>
    <table><thead><tr><th>Ov</th><th>Bowler</th><th>Balls</th><th>R</th><th>Wkt</th><th>Score</th></tr></thead>
    <tbody>${bookRows}</tbody></table>`:''}

    <div style="margin-top:16px;text-align:center;font-size:0.65rem;color:var(--muted)">${fmtDate(m.ts)}</div>
  `;
  document.getElementById('hist-modal').classList.add('show');
}

function closeHistModal(){
  document.getElementById('hist-modal').classList.remove('show');
}

async function clearHistory(){
  if(!confirm('Delete all saved match history?')) return;
  try{await KV.del(HISTORY_KEY);}catch(e){}
  renderHistory();
  showToast('History cleared');
}

function escHtml(s){
  if(!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── PWA ───────────────────────────────────────────────
let deferredPrompt=null;
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault();deferredPrompt=e;
  if(!isStandalone()){const b=document.getElementById('install-banner');b.innerHTML='📲 <button onclick="androidInstall()" style="background:var(--amber);color:#1a1a1a;border:none;border-radius:5px;padding:2px 8px;font-weight:700;cursor:pointer;font-size:0.72rem;margin:0 4px">INSTALL</button><span onclick="this.parentElement.style.display=\'none\'" style="cursor:pointer;opacity:0.5;margin-left:4px">✕</span>';b.classList.add('show');}
});
function androidInstall(){if(!deferredPrompt)return;deferredPrompt.prompt();deferredPrompt.userChoice.then(r=>{if(r.outcome==='accepted')showToast('Installed! 🎉');document.getElementById('install-banner').classList.remove('show');deferredPrompt=null;});}
function isStandalone(){return window.navigator.standalone===true||window.matchMedia('(display-mode: standalone)').matches;}

// ── INIT ─────────────────────────────────────────────
window.addEventListener('load',async()=>{
  if(/iphone|ipad|ipod/i.test(navigator.userAgent)&&!isStandalone()){
    const b=document.getElementById('install-banner');
    b.innerHTML='📲 Safari: Share → <strong>Add to Home Screen</strong> <span onclick="this.parentElement.style.display=\'none\'" style="margin-left:6px;cursor:pointer;opacity:0.5">✕</span>';
    b.classList.add('show');
  }
  if('serviceWorker' in navigator) navigator.serviceWorker.register('sw.js').catch(()=>{});
  setSyncStatus('syncing');
  await load();
  // Default openers if fresh
  if(S.batsmen.length===0){
    S.batsmen=[
      {name:'Batsman 1',runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''},
      {name:'Batsman 2',runs:0,balls:0,fours:0,sixes:0,out:false,outDesc:''},
    ];
  }
  renderAll();updateBattingCard();
  // Show takeover overlay
  const overlay=document.getElementById('spectator-overlay');
  if(overlay){
    overlay.style.display='flex';
  }else{
    console.error('spectator-overlay element not found!');
  }
  startPoll();
});
</script>
</body>
</html>
